from pyspark.sql.functions import *

batch_id = dbutils.widgets.get("batch_id")

entities = [
    "users",
    "subscriptions",
    "subscription_changes",
    "payments",
    "support_tickets"
]

for entity in entities:

    raw_path = f"/Volumes/raw_catalog/raw_schema/raw_volume/{entity}/"
    target_path = f"/Volumes/datalake/landing/raw_files/{entity}/"
    checkpoint_path = f"/Volumes/datalake/landing/raw_files/_checkpoints/{entity}/"
    schema_path = f"/Volumes/datalake/landing/raw_files/_schemas/{entity}/"

    df = (
        spark.readStream.format("cloudFiles")
        .option("cloudFiles.format", "csv")
        .option("cloudFiles.schemaLocation", schema_path)
        .option("cloudFiles.inferColumnTypes", "true")
        .option("cloudFiles.schemaEvolutionMode", "addNewColumns")
        .option("cloudFiles.maxFilesPerTrigger", 500)

        # allow reprocessing updated files
        .option("cloudFiles.allowOverwrites", "true")
        .option("cloudFiles.includeExistingFiles", "true")

        .load(raw_path)
    )

    df = (
        df.withColumn("dw_ingested_at", current_timestamp())
          # ✅ Unity Catalog compatible
          .withColumn("dw_source_file", col("_metadata.file_path"))
          .withColumn("dw_batch_id", lit(batch_id))
    )

    df = df.dropDuplicates()
    df = df.repartition(4)

    (
        df.writeStream
        .format("delta")
        .option("checkpointLocation", checkpoint_path)
        .trigger(availableNow=True)
        .start(target_path)
    )